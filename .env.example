# OpenAI / LiteLLM Configuration
# Copy this to .env and fill in your values

# The base URL for the OpenAI-compatible API
OPENAI_API_BASE=http://localhost:8000/v1

# Your API key (if using LiteLLM locally, this can usually be any string)
OPENAI_API_KEY=sk-litellm

# Model selection (LiteLLM specific)
PRIMARY_MODEL=groq-llama
GUARDRAIL_MODEL=groq-llama
